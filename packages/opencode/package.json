{
  "name": "@maicolextic/bg-subagents-opencode",
  "version": "0.1.4",
  "private": false,
  "description": "OpenCode plugin adapter for bg-subagents: registers task_bg, intercepts task, steers via chat.params, delivers completion via Bus + chat.message fallback.",
  "license": "MIT",
  "author": "Michael Jimenez <maicoljimenez360@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maicololiveras/bg-subagents.git",
    "directory": "packages/opencode"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./tui": {
      "types": "./dist/tui-plugin/index.d.ts",
      "import": "./dist/tui-plugin/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@maicolextic/bg-subagents-protocol": "workspace:*",
    "@maicolextic/bg-subagents-core": "workspace:*"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0",
    "@opencode-ai/sdk": ">=1.14.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": { "optional": false },
    "@opencode-ai/sdk": { "optional": false }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.14.20",
    "@opencode-ai/sdk": "1.14.20",
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
